{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=ai_powered_crm;User=root;Password=${DB_PASSWORD};"
  },
  "Jwt": {
    "Key": "${JWT_KEY}",
    "Issuer": "AiPoweredCrm",
    "Audience": "AiPoweredCrmUsers",
    "ExpiresInDays": 7
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}